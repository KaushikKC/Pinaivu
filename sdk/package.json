{
  "name": "@deai/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the DeAI decentralised AI inference network",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "libp2p": "^3.2.0",
    "@libp2p/tcp": "^11.0.15",
    "@libp2p/noise": "^1.0.1",
    "@libp2p/yamux": "^8.0.1",
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@libp2p/identify": "^4.1.0",
    "@libp2p/mdns": "^12.0.16",
    "@libp2p/bootstrap": "^12.0.16",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "uint8arrays": "^5.1.0",
    "it-pipe": "^3.0.1",
    "p-defer": "^4.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/src/**/*.test.ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "useESM": false,
        "tsconfig": {
          "module": "CommonJS",
          "moduleResolution": "node"
        }
      }]
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
